{
  "name": "infinitecontextwindow",
  "version": "0.1.0",
  "description": "Persistent, topic-organized memory for LLMs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.rmSync('dist/prompts',{recursive:true,force:true});fs.cpSync('src/prompts','dist/prompts',{recursive:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "eval": "tsx --env-file=.env scripts/eval.ts",
    "benchmark": "tsx --env-file=.env scripts/benchmark.ts",
    "seed-test20": "tsx --env-file=/home/thenasty/.saturday-test20/.env scripts/seed-test20.ts"
  },
  "dependencies": {},
  "peerDependencies": {
    "tiktoken": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "tiktoken": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
